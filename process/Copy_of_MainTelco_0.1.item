    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="NameTrim" expression="row1.Name != null ? row1.Name.trim() : &quot;&quot; " type="id_String"/>
        <mapperTableEntries name="vCleanName" expression="row1.Name != null &#xA;? row1.Name.trim().replaceAll(&quot;[()]&quot;, &quot;&quot;).replaceAll(&quot;\\s+&quot;, &quot;&quot;) &#xA;: &quot;&quot; " type="id_String"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out1" activateColumnNameFilter="true" columnNameFilter="&quot;ALL&quot;.equalsIgnoreCase((String)globalMap.get(&quot;targetYear&quot;))">
        <mapperTableEntries name="CustomerId" expression="row1.CustomerId " type="id_String" nullable="true"/>
        <mapperTableEntries name="Name" expression="Var.NameTrim " type="id_String" nullable="true"/>
        <mapperTableEntries name="HashCode" expression="row1.HashCode " type="id_String" nullable="true"/>
        <mapperTableEntries name="gender" expression="row2.Gender == null ? &quot;Unknown&quot; :&#xA;(row2.Gender.trim().equalsIgnoreCase(&quot;mannlich&quot;) ? &quot;M&quot; : &quot;F&quot;) " type="id_String" nullable="true"/>
        <mapperTableEntries name="email" expression="Var.vCleanName.length() &lt; 7 ? Var.vCleanName.toLowerCase() + &quot;@gmail.com&quot;&#xA;: Var.vCleanName.length() == 7 ? Var.vCleanName.toLowerCase() + &quot;@msn.com&quot;&#xA;: Var.vCleanName.length() > 7 ? Var.vCleanName.toLowerCase() + &quot;@msn.com&quot;&#xA;: &quot;&quot; " type="id_String" nullable="true"/>
        <mapperTableEntries name="Birthday" expression="TalendDate.formatDate(&quot;yyyy-MM-dd&quot;, row1.Birthday) " type="id_String" nullable="true"/>
        <mapperTableEntries name="Age" expression="TalendDate.getPartOfDate(&quot;YEAR&quot;, TalendDate.getCurrentDate()) &#xA;- TalendDate.getPartOfDate(&quot;YEAR&quot;, row1.Birthday) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="PostalCode" expression="row1.PostalCode " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="State" expression="row3.statefull == null ? &quot;Unknown State&quot;:&#xA;row3.statefull " type="id_String" nullable="true"/>
        <mapperTableEntries name="UserStatus" expression="row12.DateChurn != null ? &quot;N&quot; : &quot;Y&quot; " type="id_String" nullable="true"/>
